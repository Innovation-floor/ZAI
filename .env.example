# =============================================================================
# ZAI — Executive Humanitarian Intelligence Platform
#
# Copy this file to .env and fill in your values.
# Never commit .env to the repository.
#
# Every value is OPTIONAL. With an empty .env the stack runs entirely on
# mock and browser-native providers — a complete clickable demo, offline, free.
# =============================================================================

# --- Host ports --------------------------------------------------------------
WEB_PORT=9080
API_PORT=9010

ENVIRONMENT=development
LOG_LEVEL=INFO
DATASET_SIZE=210

# --- Language understanding --------------------------------------------------
# mock       deterministic keyword planner, offline, covers the demo script
# ollama     self-hosted models, no data leaves the network
# azure      Azure OpenAI (also works with Core42 and compatible endpoints)
# anthropic  Anthropic hosted models
LLM_PROVIDER=mock
# LLM_STRICT=false

# --- Azure OpenAI (set LLM_PROVIDER=azure) -----------------------------------
# Works with Azure OpenAI, Core42, or any Azure OpenAI-compatible endpoint.
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments
# AZURE_OPENAI_MODEL=gpt-4o
# AZURE_OPENAI_API_VERSION=2023-05-15

# --- Anthropic (set LLM_PROVIDER=anthropic) ----------------------------------
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-sonnet-4-6

# --- Ollama (set LLM_PROVIDER=ollama) ----------------------------------------
# Start Ollama with OLLAMA_HOST=0.0.0.0 or it will be unreachable from Docker.
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_PLANNER_MODEL=qwen3.5:latest
# OLLAMA_WRITER_MODEL=llama3.3:70b
# OLLAMA_NUM_CTX=8192
# OLLAMA_WRITER_NUM_CTX=16384

# --- Speech recognition (STT) -----------------------------------------------
# browser    Web Speech API in the client. Chrome/Edge supports ar-AE. Free.
# azure      Azure AI Speech — streaming STT, auto language detection
# deepgram   server-side, dialect-capable Arabic, keyword boosting
STT_PROVIDER=browser
# DEEPGRAM_API_KEY=

# --- Speech synthesis (TTS) --------------------------------------------------
# browser    Web Speech API voices (requires OS language packs for Arabic)
# azure      Azure Neural TTS — real audio for lip sync, reliable Arabic voice
TTS_PROVIDER=browser
# TTS_VOICE_AR=ar-AE-FatimaNeural
# TTS_VOICE_EN=en-US-JennyNeural

# --- Azure Speech (shared by STT and TTS when provider=azure) ----------------
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=uaenorth

# --- Avatar ------------------------------------------------------------------
# static   3D model / branded portrait. Always works. Demo insurance.
# heygen   streaming interactive avatar via LiveKit
# azure    platform-native avatar (requires S0 tier and WebRTC egress)
AVATAR_PROVIDER=static
# AVATAR_MODEL=/assets/avatar.glb
# AVATAR_MODEL_ZOOM=1.0
# AVATAR_MODEL_OFFSET_Y=0.0
AVATAR_DISPLAY_NAME=ZAI
# HEYGEN_API_KEY=
# AZURE_AVATAR_CHARACTER=lisa
# AZURE_AVATAR_STYLE=casual-sitting

# --- Documents ---------------------------------------------------------------
# local   pdfplumber. Born-digital English PDFs only.
# azure   Azure AI Document Intelligence. Arabic OCR and scanned pages.
DOCUMENT_PROVIDER=local
# AZURE_DOCINT_ENDPOINT=
# AZURE_DOCINT_KEY=
MAX_UPLOAD_MB=25
